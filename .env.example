# ---- Telegram ----
# From @BotFather after you create the bot
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# A secret you invent. Used to verify Telegram webhook calls really come from Telegram.
# Make it a long random string.
TELEGRAM_WEBHOOK_SECRET=change-me-to-a-long-random-string

# The Telegram group chat where summaries + reminders are posted.
# Negative number, e.g. -1001234567890. See SETUP.md for how to get it.
TELEGRAM_GROUP_CHAT_ID=-1001234567890

# ---- Anthropic (Claude) ----
ANTHROPIC_API_KEY=sk-ant-your-key
# Model used to parse messages. Sonnet = good balance. Switch to claude-haiku-4-5 to cut cost.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Supabase ----
SUPABASE_URL=https://yourproject.supabase.co
# Use the SERVICE ROLE key (server-side only, never expose to clients).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- App ----
TZ=Asia/Singapore
